# Variables de entorno para Docker Compose de Chappie
# Copiar este archivo como .env y llenar con tus valores reales
# Ubicación: projects/chappie-infrastructure/.env.example → .env

# ============================================
# n8n Authentication
# ============================================
N8N_USER=admin
N8N_PASSWORD=chappie2026

# ============================================
# RabbitMQ Authentication
# ============================================
RABBITMQ_USER=chappie
RABBITMQ_PASSWORD=chappie2026

# ============================================
# API Keys (llenar con tus valores)
# ============================================
GEMINI_API_KEY=
CLAUDE_API_KEY=
GPT_API_KEY=
AZURE_TTS_KEY=
